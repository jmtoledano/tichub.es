---
import Icon from "./Icon.astro"
import Badge from "./Badge.astro"
import { MODULES } from "../consts"
---

<div class="overflow-hidden rounded-2xl border border-border-strong bg-background shadow-2xl shadow-slate-900/10 ring-1 ring-slate-900/5">
  <!-- Top bar -->
  <div class="flex items-center justify-between border-b border-border px-4 py-3">
    <div class="flex items-baseline gap-2">
      <span class="text-sm font-semibold tracking-tight text-foreground">TicHub</span>
      <span class="hidden text-[9px] font-medium uppercase tracking-[0.16em] text-muted-foreground sm:inline">
        Asset Management
      </span>
    </div>
    <div class="flex items-center gap-2">
      <span class="flex h-6 w-6 items-center justify-center rounded-full bg-accent-soft text-[10px] font-semibold text-accent">A</span>
      <span class="hidden text-xs text-muted-foreground sm:inline">Administrador</span>
    </div>
  </div>

  <!-- Panel -->
  <div class="bg-muted px-4 py-4">
    <p class="mb-3 text-xs font-semibold text-foreground">Panel de módulos</p>
    <div class="grid grid-cols-2 gap-2.5 sm:grid-cols-3">
      {
        MODULES.map((mod) => (
          <div class="rounded-lg border border-border bg-card p-3">
            <div class="mb-2 flex items-center gap-2">
              <Icon name={mod.icon} class="h-4 w-4 text-muted-foreground" />
              <span class="truncate text-xs font-medium text-foreground">{mod.title}</span>
            </div>
            {mod.badges.length > 0 && (
              <div class="mb-2 flex flex-wrap gap-1">
                {mod.badges.map((b) => (
                  <Badge tone={b.tone as "blue" | "red" | "amber" | "green"} class="!px-1.5 !py-0 !text-[10px]">
                    {b.label}
                  </Badge>
                ))}
              </div>
            )}
            <div class="mt-1 h-6 rounded-md bg-accent/90" aria-hidden="true"></div>
          </div>
        ))
      }
    </div>
  </div>
</div>
