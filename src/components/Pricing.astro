---
import Icon from "./Icon.astro"
import { PRICING } from "../consts"
---

<section id="precios" class="scroll-mt-16 border-b border-border bg-background">
  <div class="section-wrap">
    <div class="section-head">
      <span class="section-eyebrow">Precios</span>
      <h2 class="section-title">
        Planes sencillos para centros educativos
      </h2>
    </div>

    <div class="mt-8 grid gap-4 lg:grid-cols-3">
      {
        PRICING.map((plan) => (
          <div
            class={`relative flex flex-col rounded-xl border p-6 ${
              plan.featured
                ? "border-accent bg-[var(--color-surface-blue)] ring-1 ring-accent/30"
                : "border-border bg-card"
            }`}
          >
            <div class="flex items-center justify-between">
              <h3 class="text-lg font-semibold text-foreground">{plan.name}</h3>
              {plan.featured && (
                <span class="inline-flex items-center gap-1 rounded-full bg-accent px-2.5 py-1 text-xs font-semibold text-accent-foreground shadow-sm">
                  Recomendado
                </span>
              )}
            </div>
            <div class="mt-3 flex items-baseline gap-2">
              <span class="text-3xl font-semibold tracking-tight text-foreground">{plan.price}</span>
              <span class="text-sm text-muted-foreground">{plan.period}</span>
            </div>
            <p class="mt-2.5 text-[0.93rem] text-muted-foreground">{plan.description}</p>

            <ul class="mt-5 flex flex-1 flex-col gap-2.5">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-2.5 text-sm text-foreground">
                  <Icon name="check" class="mt-0.5 h-4 w-4 shrink-0 text-accent" />
                  <span>{feature}</span>
                </li>
              ))}
            </ul>

            <a
              href="#demo"
              class={`mt-6 inline-flex items-center justify-center rounded-lg px-5 py-2.5 text-sm font-semibold transition-colors ${
                plan.featured
                  ? "bg-accent text-accent-foreground shadow-md shadow-accent/25 hover:bg-[var(--color-accent-hover)]"
                  : "border border-border-strong bg-background text-foreground hover:bg-muted"
              }`}
            >
              {plan.cta}
            </a>
          </div>
        ))
      }
    </div>

    <p class="mt-8 text-sm text-muted-foreground">
      Los precios finales dependen del tamaño del centro y del almacenamiento necesario. El
      alojamiento y el mantenimiento siempre están incluidos.
    </p>
  </div>
</section>
