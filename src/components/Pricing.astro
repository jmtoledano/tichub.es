---
import Icon from "./Icon.astro"
import { PRICING } from "../consts"
---

<section id="precios" class="scroll-mt-16 border-b border-border bg-muted">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-24">
    <div class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-accent">Precios</span>
      <h2 class="mt-3 text-balance text-3xl font-semibold tracking-tight text-foreground sm:text-4xl">
        Planes sencillos para centros educativos
      </h2>
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {
        PRICING.map((plan) => (
          <div
            class={`flex flex-col rounded-xl border bg-card p-7 ${
              plan.featured
                ? "border-accent shadow-lg shadow-accent/10 ring-1 ring-accent"
                : "border-border shadow-sm"
            }`}
          >
            <div class="flex items-center justify-between">
              <h3 class="text-lg font-semibold text-foreground">{plan.name}</h3>
              {plan.featured && (
                <span class="rounded-md bg-accent px-2 py-0.5 text-xs font-semibold text-accent-foreground">
                  Recomendado
                </span>
              )}
            </div>
            <div class="mt-4 flex items-baseline gap-2">
              <span class="text-3xl font-semibold tracking-tight text-foreground">{plan.price}</span>
              <span class="text-sm text-muted-foreground">{plan.period}</span>
            </div>
            <p class="mt-3 text-sm text-muted-foreground">{plan.description}</p>

            <ul class="mt-6 flex flex-1 flex-col gap-3">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-2.5 text-sm text-foreground">
                  <Icon name="check" class="mt-0.5 h-4 w-4 shrink-0 text-accent" />
                  <span>{feature}</span>
                </li>
              ))}
            </ul>

            <a
              href="#demo"
              class={`mt-7 inline-flex items-center justify-center rounded-lg px-5 py-2.5 text-sm font-semibold transition-colors ${
                plan.featured
                  ? "bg-accent text-accent-foreground hover:bg-[#2c579f]"
                  : "border border-border bg-background text-foreground hover:bg-muted"
              }`}
            >
              {plan.cta}
            </a>
          </div>
        ))
      }
    </div>

    <p class="mt-8 text-sm text-muted-foreground">
      Los precios finales dependen del tamaño del centro y del almacenamiento necesario. El
      alojamiento y el mantenimiento siempre están incluidos.
    </p>
  </div>
</section>
