---
import Wordmark from "./Wordmark.astro"
import { LEGAL_LINKS } from "../consts"

const footerLinks = [
  { label: "Funcionalidades", href: "/#funcionalidades" },
  { label: "Capturas", href: "/#capturas" },
  { label: "Precios", href: "/#precios" },
  { label: "Documentación", href: "/#documentacion" },
  { label: "Solicitar demo", href: "/#demo" },
  { label: "Contacto técnico", href: "mailto:contacto@tichub.es" },
]
---

<footer class="bg-background">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="flex flex-col gap-8 md:flex-row md:items-start md:justify-between">
      <div class="max-w-sm">
        <Wordmark />
        <p class="mt-4 text-sm leading-relaxed text-muted-foreground">
          TicHub es una plataforma modular de gestión de material para centros educativos.
        </p>
      </div>

      <nav class="grid grid-cols-2 gap-x-12 gap-y-3 sm:grid-cols-3" aria-label="Pie de página">
        {
          footerLinks.map((link) => (
            <a
              href={link.href}
              class="text-sm text-muted-foreground transition-colors hover:text-foreground"
            >
              {link.label}
            </a>
          ))
        }
      </nav>
    </div>

    <div class="mt-10 flex flex-col gap-3 border-t border-border pt-6 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2">
        {
          LEGAL_LINKS.map((link) => (
            <a
              href={link.href}
              class="text-xs text-muted-foreground transition-colors hover:text-foreground"
            >
              {link.label}
            </a>
          ))
        }
        <button
          type="button"
          id="cc-preferences-trigger"
          class="text-xs text-muted-foreground underline underline-offset-2 transition-colors hover:text-foreground"
        >
          Preferencias de cookies
        </button>
      </div>
      <p class="text-xs text-muted-foreground">© 2026 TicHub · tichub.es · Alojamiento gestionado sobre nuestra infraestructura.</p>
    </div>
  </div>
</footer>

<script>
  import * as CookieConsent from "vanilla-cookieconsent"

  document.getElementById("cc-preferences-trigger")?.addEventListener("click", () => {
    CookieConsent.showPreferences()
  })
</script>
