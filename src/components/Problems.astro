---
import Icon from "./Icon.astro"
import { PROBLEMS } from "../consts"
---

<section class="border-b border-border bg-muted">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-20">
    <div class="max-w-2xl">
      <h2 class="text-balance text-3xl font-semibold tracking-tight text-foreground sm:text-4xl">
        Cuando el material crece, el control se complica
      </h2>
      <p class="mt-4 text-pretty leading-relaxed text-muted-foreground">
        La mayoría de centros gestionan su material con herramientas que no fueron pensadas para
        ello. El resultado es información dispersa y difícil de auditar.
      </p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        PROBLEMS.map((problem) => (
          <div class="card-lift rounded-2xl border border-border bg-card p-6 shadow-sm hover:shadow-md">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-[var(--color-badge-red-bg)] text-[var(--color-badge-red)]">
              <Icon name={problem.icon} class="h-5 w-5" />
            </div>
            <h3 class="mt-4 text-base font-semibold text-foreground">{problem.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{problem.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
