---
import InventoryMockup from "./mockups/InventoryMockup.astro"
import IncidentsMockup from "./mockups/IncidentsMockup.astro"
import LoansMockup from "./mockups/LoansMockup.astro"
import { SCREENSHOTS } from "../consts"

const mockups = {
  Inventario: InventoryMockup,
  Incidencias: IncidentsMockup,
  Préstamos: LoansMockup,
} as const
---

<section id="capturas" class="scroll-mt-16 border-b border-border bg-muted">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-24">
    <div class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-accent">Capturas</span>
      <h2 class="mt-3 text-balance text-3xl font-semibold tracking-tight text-foreground sm:text-4xl">
        Así se ve TicHub por dentro
      </h2>
      <p class="mt-4 text-pretty leading-relaxed text-muted-foreground">
        Pantallas reales de la plataforma. Cada módulo comparte el mismo lenguaje visual: listados
        claros, buscadores, filtros y estados con color para leer de un vistazo.
      </p>
    </div>

    <div class="mt-12 flex flex-col gap-12 lg:gap-16">
      {
        SCREENSHOTS.map((shot, index) => {
          const Mockup = mockups[shot.title as keyof typeof mockups]
          return (
            <div
              class:list={[
                "grid items-center gap-6 lg:grid-cols-2 lg:gap-12",
                index % 2 === 1 && "lg:[&>.mockup]:order-2",
              ]}
            >
              <div class="mockup">
                <Mockup />
              </div>
              <div class="max-w-md">
                <h3 class="text-xl font-semibold text-foreground">{shot.title}</h3>
                <p class="mt-3 text-pretty leading-relaxed text-muted-foreground">{shot.description}</p>
              </div>
            </div>
          )
        })
      }
    </div>
  </div>
</section>
