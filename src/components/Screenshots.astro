---
import Icon from "./Icon.astro"
import InventoryMockup from "./mockups/InventoryMockup.astro"
import IncidentsMockup from "./mockups/IncidentsMockup.astro"
import LoansMockup from "./mockups/LoansMockup.astro"
import PurchasesMockup from "./mockups/PurchasesMockup.astro"
import ConsumablesMockup from "./mockups/ConsumablesMockup.astro"
import AuditMockup from "./mockups/AuditMockup.astro"
import { SCREENSHOTS } from "../consts"

const mockups = {
  Inventario: InventoryMockup,
  Incidencias: IncidentsMockup,
  Préstamos: LoansMockup,
  Compras: PurchasesMockup,
  Consumibles: ConsumablesMockup,
  Auditoría: AuditMockup,
} as const
---

<section id="capturas" class="scroll-mt-16 border-b border-border bg-muted">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-24">
    <div class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-accent">Capturas</span>
      <h2 class="mt-3 text-balance text-3xl font-semibold tracking-tight text-foreground sm:text-4xl">
        Así se ve TicHub por dentro
      </h2>
      <p class="mt-4 text-pretty leading-relaxed text-muted-foreground">
        Pantallas reales de la plataforma. Cada módulo comparte el mismo lenguaje visual: listados
        claros, buscadores, filtros y estados con color para leer de un vistazo.
      </p>
    </div>

    <div class="mt-10" data-carousel>
      <div class="flex flex-wrap gap-2" role="tablist" aria-label="Módulos">
        {
          SCREENSHOTS.map((shot, index) => (
            <button
              type="button"
              role="tab"
              data-carousel-tab={index}
              aria-selected={index === 0 ? "true" : "false"}
              class:list={[
                "carousel-tab rounded-full border px-4 py-2 text-sm font-medium transition-colors",
                index === 0
                  ? "border-accent bg-accent text-accent-foreground"
                  : "border-border bg-card text-muted-foreground hover:text-foreground",
              ]}
            >
              {shot.title}
            </button>
          ))
        }
      </div>

      <div class="relative mt-8">
        <button
          type="button"
          data-carousel-prev
          aria-label="Captura anterior"
          class="absolute -left-3 top-1/2 z-10 hidden -translate-y-1/2 items-center justify-center rounded-full border border-border-strong bg-background p-2 text-foreground shadow-md transition-colors hover:bg-muted sm:-left-5 lg:flex"
        >
          <Icon name="arrow" class="h-4 w-4 rotate-180" />
        </button>
        <button
          type="button"
          data-carousel-next
          aria-label="Siguiente captura"
          class="absolute -right-3 top-1/2 z-10 hidden -translate-y-1/2 items-center justify-center rounded-full border border-border-strong bg-background p-2 text-foreground shadow-md transition-colors hover:bg-muted sm:-right-5 lg:flex"
        >
          <Icon name="arrow" class="h-4 w-4" />
        </button>

        {
          SCREENSHOTS.map((shot, index) => {
            const Mockup = mockups[shot.title as keyof typeof mockups]
            return (
              <div data-carousel-slide={index} class="carousel-slide" hidden={index !== 0}>
                <div class="grid items-center gap-6 lg:grid-cols-2 lg:gap-12">
                  <div>
                    <Mockup />
                  </div>
                  <div class="max-w-md">
                    <h3 class="text-xl font-semibold text-foreground">{shot.title}</h3>
                    <p class="mt-3 text-pretty leading-relaxed text-muted-foreground">{shot.description}</p>
                  </div>
                </div>
              </div>
            )
          })
        }
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>("[data-carousel]").forEach((carousel) => {
    const tabs = Array.from(carousel.querySelectorAll<HTMLButtonElement>("[data-carousel-tab]"))
    const slides = Array.from(carousel.querySelectorAll<HTMLElement>("[data-carousel-slide]"))
    const prevBtn = carousel.querySelector<HTMLButtonElement>("[data-carousel-prev]")
    const nextBtn = carousel.querySelector<HTMLButtonElement>("[data-carousel-next]")
    let active = 0

    const activeClasses = ["border-accent", "bg-accent", "text-accent-foreground"]
    const inactiveClasses = ["border-border", "bg-card", "text-muted-foreground"]
    const offsetPx = 16

    const goTo = (rawIndex: number) => {
      const nextIndex = (rawIndex + slides.length) % slides.length
      if (nextIndex === active) return

      const direction = rawIndex < 0 ? -1 : rawIndex >= slides.length ? 1 : rawIndex > active ? 1 : -1

      tabs.forEach((tab, i) => {
        const isActive = i === nextIndex
        tab.setAttribute("aria-selected", String(isActive))
        activeClasses.forEach((c) => tab.classList.toggle(c, isActive))
        inactiveClasses.forEach((c) => tab.classList.toggle(c, !isActive))
      })

      const current = slides[active]
      const next = slides[nextIndex]

      current.hidden = true
      next.hidden = false
      next.style.transition = "none"
      next.style.opacity = "0"
      next.style.transform = `translateX(${direction * offsetPx}px)`
      // Fuerza el reflow para que el navegador registre el estado inicial
      // antes de animar hacia el estado final (si no, no hay transición).
      next.getBoundingClientRect()
      next.style.transition = ""
      requestAnimationFrame(() => {
        next.style.opacity = "1"
        next.style.transform = "translateX(0)"
      })

      active = nextIndex
    }

    tabs.forEach((tab, i) => tab.addEventListener("click", () => goTo(i)))
    prevBtn?.addEventListener("click", () => goTo(active - 1))
    nextBtn?.addEventListener("click", () => goTo(active + 1))
  })
</script>
