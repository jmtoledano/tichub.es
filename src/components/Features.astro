---
import Icon from "./Icon.astro"
import { FEATURES } from "../consts"
---

<section id="funcionalidades" class="scroll-mt-16 border-b border-border bg-background">
  <div class="section-wrap">
    <div class="section-head">
      <span class="section-eyebrow">Funcionalidades</span>
      <h2 class="section-title">
        Todo el ciclo de vida del material en un solo lugar
      </h2>
      <p class="section-copy">
        Módulos que se conectan entre sí para que cada equipo, préstamo o incidencia deje rastro y
        se pueda consultar cuando haga falta.
      </p>
    </div>

    <div class="mt-8 grid items-start gap-3.5 sm:grid-cols-2 lg:grid-cols-4" data-features-grid>
      {
        FEATURES.map((feature, index) => (
          <article class="feature-card card-lift rounded-xl border border-border bg-card p-5 hover:border-border-strong" data-feature-card>
            <button
              type="button"
              class="summary-reset flex w-full items-center gap-3 text-left"
              aria-expanded="false"
              aria-controls={`feature-panel-${index}`}
              data-feature-trigger
            >
              <span class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-accent-soft text-accent">
                <Icon name={feature.icon} class="h-5 w-5" />
              </span>
              <h3 class="flex-1 text-base font-semibold text-foreground">{feature.title}</h3>
              <Icon name="arrow" class="feature-chevron h-4 w-4 shrink-0 text-muted-foreground transition-transform duration-200" />
            </button>
            <div
              id={`feature-panel-${index}`}
              class="feature-popover mt-3 text-[0.93rem] leading-relaxed text-muted-foreground"
              data-feature-panel
              hidden
            >
              {feature.description}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>("[data-features-grid]").forEach((grid) => {
    const desktopQuery = window.matchMedia("(min-width: 1024px)")
    const cards = Array.from(grid.querySelectorAll<HTMLElement>("[data-feature-card]"))

    const updatePanelDirection = (card: HTMLElement) => {
      const panel = card.querySelector<HTMLElement>("[data-feature-panel]")
      if (!panel) return

      if (!desktopQuery.matches) {
        card.classList.remove("is-open-up")
        return
      }

      const cardRect = card.getBoundingClientRect()
      const panelHeight = panel.scrollHeight
      const spacing = 10
      const spaceBelow = window.innerHeight - cardRect.bottom
      const spaceAbove = cardRect.top
      const shouldOpenUp = panelHeight + spacing > spaceBelow && spaceAbove > spaceBelow

      card.classList.toggle("is-open-up", shouldOpenUp)
    }

    const closeCard = (card: HTMLElement) => {
      if (!card.classList.contains("is-open")) return

      const trigger = card.querySelector<HTMLButtonElement>("[data-feature-trigger]")
      const panel = card.querySelector<HTMLElement>("[data-feature-panel]")
      if (!trigger || !panel) return

      const panelHeight = panel.scrollHeight
      panel.style.overflow = "hidden"
      panel.style.height = `${panelHeight}px`
      panel.style.opacity = "1"
      panel.style.transform = "translateY(0) scale(1)"
      panel.getBoundingClientRect()
      panel.style.transition = "height 200ms ease, opacity 180ms ease, transform 200ms ease"
      panel.style.height = "0px"
      panel.style.opacity = "0"
      panel.style.transform = "translateY(4px) scale(0.985)"

      const onCloseEnd = (event: TransitionEvent) => {
        if (event.propertyName !== "height") return
        panel.hidden = true
        panel.style.height = ""
        panel.style.overflow = ""
        panel.style.opacity = ""
        panel.style.transform = ""
        panel.style.transition = ""
        panel.removeEventListener("transitionend", onCloseEnd)
      }

      panel.addEventListener("transitionend", onCloseEnd)
      card.classList.remove("is-open")
      trigger.setAttribute("aria-expanded", "false")
    }

    const openCard = (card: HTMLElement) => {
      const trigger = card.querySelector<HTMLButtonElement>("[data-feature-trigger]")
      const panel = card.querySelector<HTMLElement>("[data-feature-panel]")
      if (!trigger || !panel) return

      updatePanelDirection(card)

      cards.forEach((other) => {
        if (other !== card) closeCard(other)
      })

      if (card.classList.contains("is-open")) {
        closeCard(card)
        return
      }

      panel.hidden = false
      panel.style.overflow = "hidden"
      panel.style.height = "0px"
      panel.style.opacity = "0"
      panel.style.transform = "translateY(4px) scale(0.985)"
      panel.getBoundingClientRect()

      const panelHeight = panel.scrollHeight
      panel.style.transition = "height 220ms ease, opacity 180ms ease, transform 220ms ease"
      panel.style.height = `${panelHeight}px`
      panel.style.opacity = "1"
      panel.style.transform = "translateY(0) scale(1)"

      const onOpenEnd = (event: TransitionEvent) => {
        if (event.propertyName !== "height") return
        panel.style.height = ""
        panel.style.overflow = ""
        panel.style.transition = ""
        panel.removeEventListener("transitionend", onOpenEnd)
      }

      panel.addEventListener("transitionend", onOpenEnd)
      card.classList.add("is-open")
      trigger.setAttribute("aria-expanded", "true")
    }

    const refreshOpenCardsDirection = () => {
      cards.forEach((card) => {
        if (card.classList.contains("is-open")) updatePanelDirection(card)
      })
    }

    cards.forEach((card) => {
      const trigger = card.querySelector<HTMLButtonElement>("[data-feature-trigger]")
      trigger?.addEventListener("click", () => openCard(card))
    })

    window.addEventListener("resize", refreshOpenCardsDirection)
    window.addEventListener("scroll", refreshOpenCardsDirection, { passive: true })
    desktopQuery.addEventListener("change", refreshOpenCardsDirection)
  })
</script>
