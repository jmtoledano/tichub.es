---
import Icon from "./Icon.astro"
import { FEATURES } from "../consts"
---

<section id="funcionalidades" class="scroll-mt-16 border-b border-border bg-background">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-24">
    <div class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-accent">Funcionalidades</span>
      <h2 class="mt-3 text-balance text-3xl font-semibold tracking-tight text-foreground sm:text-4xl">
        Todo el ciclo de vida del material en un solo lugar
      </h2>
      <p class="mt-4 text-pretty leading-relaxed text-muted-foreground">
        Módulos que se conectan entre sí para que cada equipo, préstamo o incidencia deje rastro y
        se pueda consultar cuando haga falta.
      </p>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
        FEATURES.map((feature) => (
          <div class="card-lift rounded-2xl border border-border bg-card p-6 shadow-sm hover:border-accent/40 hover:shadow-md">
            <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-accent-soft text-accent">
              <Icon name={feature.icon} class="h-5 w-5" />
            </div>
            <h3 class="mt-4 text-base font-semibold text-foreground">{feature.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{feature.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
