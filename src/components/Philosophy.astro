---
import Icon from "./Icon.astro"
import { PHILOSOPHY } from "../consts"

const PAGE_SIZE = 3
const pages = Array.from({ length: Math.ceil(PHILOSOPHY.length / PAGE_SIZE) }, (_, i) =>
  PHILOSOPHY.slice(i * PAGE_SIZE, i * PAGE_SIZE + PAGE_SIZE),
)
---

<section class="relative overflow-hidden border-y border-[var(--color-ink-border)] bg-[var(--color-ink)] text-[var(--color-ink-foreground)]">
  <!-- Ambient bloom for depth -->
  <div
    class="pointer-events-none absolute -left-24 top-0 h-72 w-72 rounded-full opacity-40 blur-3xl"
    style="background: radial-gradient(circle, var(--color-accent-bright) 0%, transparent 70%);"
    aria-hidden="true"
  >
  </div>

  <div class="section-wrap relative grid gap-12 lg:grid-cols-[0.85fr_1.15fr] lg:items-center">
    <div>
      <span class="section-eyebrow text-[var(--color-accent-bright)]">Filosofía</span>
      <h2 class="section-title mt-2.5 text-[var(--color-ink-foreground)]">
        Diseñado para centros reales, no para departamentos gigantes
      </h2>
      <p class="section-copy text-[var(--color-ink-muted)]">
        TicHub asume que quien lo usa tiene poco tiempo y muchas otras responsabilidades. Por eso
        prioriza la claridad y la trazabilidad sin obligar a montar procesos complejos.
      </p>
    </div>

    <!-- Muestra 3 puntos a la vez y rota automáticamente al siguiente grupo de 3
         (en vez de apilar los 6). Ver el <script> más abajo. -->
    <div class="relative" data-philosophy>
      {
        pages.map((page, pageIndex) => (
          <ol
            class="philosophy-page grid gap-px overflow-hidden rounded-xl border border-[var(--color-ink-border)] bg-[var(--color-ink-border)]"
            data-philosophy-page={pageIndex}
          >
            {page.map((point) => (
              <li class="flex items-start gap-4 bg-[var(--color-ink)] px-5 py-5">
                <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-md bg-[color-mix(in_oklab,var(--color-accent-bright)_18%,transparent)] text-[var(--color-accent-bright)]">
                  <Icon name="check" class="h-4 w-4" />
                </span>
                <span class="text-[0.98rem] leading-relaxed text-[var(--color-ink-foreground)]">{point}</span>
              </li>
            ))}
          </ol>
        ))
      }
    </div>
  </div>
</section>

<style>
  .philosophy-page {
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
  }
  .philosophy-page.is-absolute {
    position: absolute;
    inset: 0;
  }
  .philosophy-page.is-hidden {
    opacity: 0;
    pointer-events: none;
    transform: translateY(6px);
  }
  @media (prefers-reduced-motion: reduce) {
    .philosophy-page {
      transition: none;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>("[data-philosophy]").forEach((container) => {
    const pages = Array.from(container.querySelectorAll<HTMLElement>("[data-philosophy-page]"))
    if (pages.length <= 1) return

    // Con el movimiento reducido activado, se dejan todas las páginas apiladas y
    // estáticas (sin rotación) para no ocultar contenido detrás de un temporizador.
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return

    container.style.position = "relative"
    const maxHeight = Math.max(...pages.map((p) => p.getBoundingClientRect().height))
    container.style.height = `${maxHeight}px`

    pages.forEach((page, i) => {
      page.classList.add("is-absolute")
      if (i !== 0) page.classList.add("is-hidden")
    })

    let index = 0
    setInterval(() => {
      const current = pages[index]
      index = (index + 1) % pages.length
      const next = pages[index]
      current.classList.add("is-hidden")
      next.classList.remove("is-hidden")
    }, 4200)
  })
</script>
