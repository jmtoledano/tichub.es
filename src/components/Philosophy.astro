---
import Icon from "./Icon.astro"
import { PHILOSOPHY } from "../consts"
---

<section class="border-b border-border bg-[var(--color-surface-blue)]">
  <div class="section-wrap grid gap-10 lg:grid-cols-2 lg:items-center">
    <div>
      <h2 class="section-title mt-0">
        Diseñado para centros reales, no para departamentos gigantes
      </h2>
      <p class="section-copy">
        TicHub asume que quien lo usa tiene poco tiempo y muchas otras responsabilidades. Por eso
        prioriza la claridad y la trazabilidad sin obligar a montar procesos complejos.
      </p>
    </div>

    <ul class="grid gap-2.5">
      {
        PHILOSOPHY.map((point) => (
          <li class="flex items-start gap-3 rounded-lg border border-border/80 bg-card p-3.5">
            <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-accent-soft text-accent">
              <Icon name="check" class="h-4 w-4" />
            </span>
            <span class="text-sm leading-relaxed text-foreground">{point}</span>
          </li>
        ))
      }
    </ul>
  </div>
</section>
