---
import Icon from "./Icon.astro"
import { DOCS } from "../consts"
---

<section id="documentacion" class="scroll-mt-16 border-b border-border bg-muted">
  <div class="mx-auto max-w-6xl px-4 py-16 sm:px-6 lg:py-24">
    <div class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-accent">Documentación</span>
      <h2 class="mt-3 text-balance text-3xl font-semibold tracking-tight text-foreground sm:text-4xl">
        Documentación clara para equipos técnicos
      </h2>
      <p class="mt-4 text-pretty leading-relaxed text-muted-foreground">
        Guías paso a paso para instalar, desplegar y mantener TicHub sin depender de nadie.
      </p>
    </div>

    <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        DOCS.map((doc) => (
          <a
            href="#"
            class="card-lift group flex items-center justify-between rounded-2xl border border-border bg-card p-5 shadow-sm hover:border-accent hover:shadow-md"
          >
            <span class="flex items-center gap-3">
              <span class="flex h-9 w-9 items-center justify-center rounded-lg bg-accent-soft text-accent">
                <Icon name={doc.icon} class="h-4 w-4" />
              </span>
              <span class="text-sm font-medium text-foreground">{doc.title}</span>
            </span>
            <Icon name="arrow" class="h-4 w-4 text-muted-foreground transition-colors group-hover:text-accent" />
          </a>
        ))
      }
    </div>
  </div>
</section>
