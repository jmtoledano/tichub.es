---
import Layout from "../layouts/Layout.astro"
import Header from "./Header.astro"
import Footer from "./Footer.astro"

interface Props {
  title: string
  updated: string
}

const { title, updated } = Astro.props
---

<Layout title={title}>
  <Header />
  <main>
    <section class="border-b border-border bg-background">
      <div class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:py-20">
        <h1 class="text-3xl font-semibold tracking-tight text-foreground sm:text-4xl">{title}</h1>
        <p class="mt-2 text-sm text-muted-foreground">Última actualización: {updated}</p>
        <div class="legal-content mt-10 space-y-4 text-pretty leading-relaxed text-muted-foreground">
          <slot />
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
