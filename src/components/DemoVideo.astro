---
---

<section id="demo" class="scroll-mt-16 border-b border-border bg-background">
  <div class="mx-auto max-w-6xl px-4 py-10 sm:px-6 lg:py-14">
    <div class="mx-auto max-w-xl text-center">
      <h2 class="section-title">
        TicHub en 1 minuto
      </h2>
      <p class="section-copy">
        Una visión rápida de cómo TicHub conecta inventario, préstamos, incidencias, consumibles,
        compras y trazabilidad.
      </p>
    </div>

    <div class="relative mx-auto mt-6 max-w-[800px]" data-video-frame>
      <div class="relative overflow-hidden rounded-2xl border border-border-strong bg-slate-950 shadow-[var(--shadow-xl)]">
        <video
          controls
          preload="metadata"
          playsinline
          poster="/images/poster.png"
          class="block aspect-video w-full"
          aria-label="Vídeo breve de presentación de TicHub"
          data-video
        >
          <source src="/videos/tichub-demo.mp4" type="video/mp4" />
          <track kind="subtitles" src="/videos/tichub-demo.vtt" srclang="es" label="Español" default />
          Tu navegador no soporta la reproducción de vídeo HTML5.
        </video>

        <div
          class="pointer-events-none absolute inset-0 flex items-center justify-center transition-opacity duration-200"
          data-play-overlay
        >
          <button
            type="button"
            class="pointer-events-auto flex h-16 w-16 items-center justify-center rounded-full bg-background/95 text-accent shadow-[var(--shadow-lg)] transition-transform hover:scale-105 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2"
            aria-label="Reproducir vídeo"
            data-play-button
          >
            <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" class="ml-0.5" aria-hidden="true">
              <path d="M7 5.5v13a1 1 0 0 0 1.53.85l10.5-6.5a1 1 0 0 0 0-1.7l-10.5-6.5A1 1 0 0 0 7 5.5Z" />
            </svg>
          </button>
        </div>
      </div>
    </div>

    <div class="mx-auto mt-6 flex max-w-xl flex-wrap items-center justify-center gap-4 text-center">
      <p class="text-[0.97rem] text-muted-foreground">¿Quieres verlo funcionando de verdad?</p>
      <a
        href="#solicitar-demo"
        class="inline-flex items-center justify-center rounded-lg bg-accent px-6 py-3 text-sm font-semibold text-accent-foreground shadow-[var(--shadow-md)] transition-all hover:-translate-y-0.5 hover:bg-[var(--color-accent-hover)] hover:shadow-[var(--shadow-lg)]"
      >
        Solicitar demo
      </a>
    </div>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: reduce) {
    [data-play-overlay],
    [data-play-button] {
      transition: none !important;
    }
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>("[data-video-frame]").forEach((frame) => {
    const video = frame.querySelector<HTMLVideoElement>("[data-video]")
    const overlay = frame.querySelector<HTMLElement>("[data-play-overlay]")
    const playButton = frame.querySelector<HTMLButtonElement>("[data-play-button]")
    if (!video || !overlay || !playButton) return

    playButton.addEventListener("click", () => video.play())
    video.addEventListener("play", () => overlay.classList.add("opacity-0"))
    video.addEventListener("pause", () => overlay.classList.remove("opacity-0"))
    video.addEventListener("ended", () => overlay.classList.remove("opacity-0"))
  })
</script>
