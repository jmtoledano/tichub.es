---
import Icon from "../Icon.astro"
import Badge from "../Badge.astro"

const rows = [
  { borrower: "Laura Sánchez", dept: "Dpto. Ciencias", items: "2/2", period: "12 mar – 26 mar", status: "Activo", tone: "blue" },
  { borrower: "Grupo 4ºB", dept: "Tutoría", items: "1/2", period: "05 mar – 19 mar", status: "Devolución parcial", tone: "amber" },
  { borrower: "Marcos Ortega", dept: "Dpto. Tecnología", items: "0/3", period: "20 feb – 06 mar", status: "Vencido", tone: "red" },
  { borrower: "Ana Belén Ruiz", dept: "Biblioteca", items: "2/2", period: "01 mar – 08 mar", status: "Devuelto", tone: "green" },
] as const
---

<div class="overflow-hidden rounded-2xl border border-border-strong bg-background shadow-xl shadow-slate-900/10 ring-1 ring-slate-900/5">
  <!-- Top bar -->
  <div class="flex items-center justify-between border-b border-border px-4 py-3">
    <div>
      <span class="text-sm font-semibold tracking-tight text-foreground">Préstamos</span>
      <p class="text-[11px] text-muted-foreground">8 préstamos</p>
    </div>
    <span class="inline-flex items-center gap-1 rounded-md bg-accent px-2.5 py-1 text-[11px] font-semibold text-accent-foreground shadow-sm shadow-accent/25">
      + Nuevo préstamo
    </span>
  </div>

  <!-- Filters -->
  <div class="flex flex-wrap items-center gap-2 border-b border-border bg-muted px-4 py-3">
    <div class="flex min-w-[120px] flex-1 items-center gap-1.5 rounded-md border border-border bg-card px-2 py-1.5 text-[11px] text-muted-foreground">
      <Icon name="eye" class="h-3.5 w-3.5" />
      <span>Buscar prestatario…</span>
    </div>
    {["Estado", "Fechas", "10 / pág."].map((f) => (
      <div class="hidden items-center justify-between gap-2 rounded-md border border-border bg-card px-2 py-1.5 text-[11px] text-muted-foreground sm:flex">
        <span>{f}</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3 w-3" aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg>
      </div>
    ))}
  </div>

  <!-- Table -->
  <div class="px-2 py-1">
    <table class="w-full border-collapse text-left">
      <thead>
        <tr class="border-b-2 border-border text-[10px] font-semibold uppercase tracking-wider text-muted-foreground">
          <th class="px-2 py-2.5">Prestatario</th>
          <th class="px-2 py-2.5">Artículos</th>
          <th class="hidden px-2 py-2.5 sm:table-cell">Período</th>
          <th class="px-2 py-2.5">Estado</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((r, i) => (
          <tr class:list={["text-[11px]", i % 2 === 1 && "bg-muted/60"]}>
            <td class="px-2 py-2">
              <div class="font-medium text-foreground">{r.borrower}</div>
              <div class="hidden text-[10px] text-muted-foreground sm:block">{r.dept}</div>
            </td>
            <td class="px-2 py-2">
              <span class="inline-flex items-center rounded-md border border-border bg-card px-1.5 py-0.5 font-mono text-[10px] font-medium text-foreground">{r.items}</span>
            </td>
            <td class="hidden px-2 py-2 text-muted-foreground sm:table-cell">{r.period}</td>
            <td class="px-2 py-2">
              <Badge tone={r.tone} class="!px-1.5 !py-0 !text-[10px]">{r.status}</Badge>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>
