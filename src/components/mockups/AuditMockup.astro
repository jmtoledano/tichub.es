---
import Icon from "../Icon.astro"

const rows = [
  { user: "Marta Sánchez", action: "Creó el artículo «Proyector Epson EB-X06»", when: "hace 12 min", dot: "bg-[var(--color-badge-blue)]" },
  { user: "David Romero", action: "Cerró la incidencia #482", when: "hace 1 h", dot: "bg-[var(--color-badge-green)]" },
  { user: "Javier Delgado", action: "Cerró la compra COMP-2026-0006", when: "hace 3 h", dot: "bg-[var(--color-badge-green)]" },
  { user: "Carmen Vidal", action: "Registró la devolución del préstamo #128", when: "hace 5 h", dot: "bg-[var(--color-badge-amber)]" },
] as const
---

<div class="overflow-hidden rounded-2xl border border-border-strong bg-background shadow-xl shadow-slate-900/10 ring-1 ring-slate-900/5">
  <!-- Top bar -->
  <div class="flex items-center justify-between border-b border-border px-4 py-3">
    <div>
      <span class="text-sm font-semibold tracking-tight text-foreground">Auditoría</span>
      <p class="text-[11px] text-muted-foreground">Actividad reciente</p>
    </div>
    <span class="inline-flex items-center gap-1 rounded-md border border-border bg-card px-2.5 py-1 text-[11px] font-semibold text-foreground shadow-sm">
      Exportar CSV
    </span>
  </div>

  <!-- Filters -->
  <div class="flex flex-wrap items-center gap-2 border-b border-border bg-muted px-4 py-3">
    <div class="flex min-w-[120px] flex-1 items-center gap-1.5 rounded-md border border-border bg-card px-2 py-1.5 text-[11px] text-muted-foreground">
      <Icon name="eye" class="h-3.5 w-3.5" />
      <span>Buscar en auditoría…</span>
    </div>
    {["Módulo", "Usuario", "Fechas"].map((f) => (
      <div class="hidden items-center justify-between gap-2 rounded-md border border-border bg-card px-2 py-1.5 text-[11px] text-muted-foreground sm:flex">
        <span>{f}</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="h-3 w-3" aria-hidden="true"><path d="m6 9 6 6 6-6" /></svg>
      </div>
    ))}
  </div>

  <!-- Table -->
  <div class="px-2 py-1">
    <table class="w-full border-collapse text-left">
      <thead>
        <tr class="border-b-2 border-border text-[10px] font-semibold uppercase tracking-wider text-muted-foreground">
          <th class="px-2 py-2.5">Acción</th>
          <th class="hidden px-2 py-2.5 sm:table-cell">Usuario</th>
          <th class="px-2 py-2.5">Cuándo</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((r, i) => (
          <tr class:list={["text-[11px]", i % 2 === 1 && "bg-muted/60"]}>
            <td class="px-2 py-2">
              <div class="flex items-center gap-2">
                <span class={`h-1.5 w-1.5 shrink-0 rounded-full ${r.dot}`} aria-hidden="true"></span>
                <span class="font-medium text-foreground">{r.action}</span>
              </div>
              <div class="pl-3.5 text-[10px] text-muted-foreground sm:hidden">{r.user}</div>
            </td>
            <td class="hidden px-2 py-2 text-muted-foreground sm:table-cell">{r.user}</td>
            <td class="px-2 py-2 whitespace-nowrap text-muted-foreground">{r.when}</td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>
