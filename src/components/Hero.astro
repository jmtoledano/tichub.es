---
import Icon from "./Icon.astro";
import DashboardMockup from "./DashboardMockup.astro";
---

<section class="relative overflow-hidden border-b border-border bg-background">
  <div class="pointer-events-none absolute inset-0 bg-grid opacity-60"></div>

  <div class="section-wrap relative grid items-center gap-10 lg:grid-cols-2">
    <div>
      <span
        class="inline-flex items-center gap-2 rounded-full border border-border bg-background px-3 py-1 text-[0.72rem] font-semibold uppercase tracking-[0.12em] text-muted-foreground shadow-[var(--shadow-xs)]"
      >
        <span class="relative flex h-1.5 w-1.5">
          <span class="absolute inline-flex h-full w-full rounded-full bg-accent opacity-60"></span>
          <span class="relative inline-flex h-1.5 w-1.5 rounded-full bg-accent"></span>
        </span>
        Plataforma para centros educativos
      </span>

      <h1
        class="mt-5 max-w-xl text-balance font-display text-[2.6rem] font-medium leading-[1.04] tracking-[-0.015em] text-foreground sm:text-[3.4rem]"
      >
        Todo el material técnico de tu centro,
        <span class="italic text-accent">bajo control</span>
      </h1>

      <p
        class="mt-5 max-w-xl text-pretty text-[1.02rem] leading-relaxed text-muted-foreground sm:text-lg"
      >
        TicHub centraliza el inventario, los préstamos, las incidencias, los
        consumibles, las compras y la documentación técnica de un centro
        educativo en una plataforma clara, trazable y fácil de usar.
      </p>

      <div class="mt-7 flex flex-col gap-3 sm:flex-row">
        <a
          href="#demo"
          class="group inline-flex items-center justify-center gap-2 rounded-lg bg-accent px-6 py-3.5 text-sm font-semibold text-accent-foreground shadow-[var(--shadow-md)] transition-all hover:-translate-y-0.5 hover:bg-[var(--color-accent-hover)] hover:shadow-[var(--shadow-lg)]"
        >
          Solicitar demo
          <Icon name="arrow" class="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
        </a>
        <a
          href="#funcionalidades"
          class="inline-flex items-center justify-center rounded-lg border border-border-strong bg-background px-6 py-3.5 text-sm font-semibold text-foreground shadow-[var(--shadow-xs)] transition-colors hover:border-accent hover:bg-accent-soft hover:text-accent"
        >
          Ver funcionalidades
        </a>
      </div>
    </div>

    <div class="relative lg:pl-2">
      <!-- Soft blue glow -->
      <div
        class="pointer-events-none absolute -inset-6 -z-10 hero-glow"
        aria-hidden="true"
      >
      </div>

      <DashboardMockup />
    </div>
  </div>
</section>
