---
import Icon from "./Icon.astro"
import DashboardMockup from "./DashboardMockup.astro"
---

<section class="relative overflow-hidden border-b border-border bg-background">
  <div class="pointer-events-none absolute inset-0 bg-grid opacity-60"></div>

  <div class="relative mx-auto grid max-w-6xl items-center gap-12 px-4 py-16 sm:px-6 lg:grid-cols-2 lg:py-24">
    <div>
      <span class="inline-flex items-center gap-2 rounded-full border border-border bg-muted px-3 py-1 text-xs font-medium text-muted-foreground">
        <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
        Plataforma para centros educativos
      </span>

      <h1 class="mt-5 text-balance text-4xl font-semibold leading-tight tracking-tight text-foreground sm:text-5xl">
        Gestión de material, préstamos e incidencias para centros educativos
      </h1>

      <p class="mt-5 max-w-xl text-pretty text-base leading-relaxed text-muted-foreground sm:text-lg">
        TicHub centraliza el inventario, los préstamos, las incidencias, los consumibles y la
        documentación técnica de un centro educativo en una plataforma clara, trazable y fácil de
        usar.
      </p>

      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href="#demo"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-accent px-6 py-3.5 text-sm font-semibold text-accent-foreground shadow-lg shadow-accent/25 transition-all hover:bg-[var(--color-accent-hover)] hover:shadow-xl hover:shadow-accent/30"
        >
          Solicitar demo
          <Icon name="arrow" class="h-4 w-4" />
        </a>
        <a
          href="#funcionalidades"
          class="inline-flex items-center justify-center rounded-lg border border-border-strong bg-background px-6 py-3.5 text-sm font-semibold text-foreground transition-colors hover:bg-muted"
        >
          Ver funcionalidades
        </a>
      </div>
    </div>

    <div class="relative lg:pl-4">
      <!-- Soft blue glow -->
      <div class="pointer-events-none absolute -inset-6 -z-10 hero-glow" aria-hidden="true"></div>

      <DashboardMockup />

      <!-- Floating status pills -->
      <div class="pointer-events-none absolute -left-3 top-8 hidden rounded-xl border border-border bg-background/95 px-3 py-2 shadow-lg shadow-slate-900/10 backdrop-blur-sm sm:flex sm:items-center sm:gap-2 lg:-left-6">
        <span class="flex h-2 w-2 rounded-full bg-[var(--color-badge-red)]" aria-hidden="true"></span>
        <span class="text-xs font-semibold text-foreground">13 incidencias pendientes</span>
      </div>
      <div class="pointer-events-none absolute -right-3 top-1/2 hidden rounded-xl border border-border bg-background/95 px-3 py-2 shadow-lg shadow-slate-900/10 backdrop-blur-sm sm:flex sm:items-center sm:gap-2 lg:-right-6">
        <span class="flex h-2 w-2 rounded-full bg-[var(--color-badge-amber)]" aria-hidden="true"></span>
        <span class="text-xs font-semibold text-foreground">2 préstamos vencidos</span>
      </div>
      <div class="pointer-events-none absolute -bottom-4 left-10 hidden rounded-xl border border-border bg-background/95 px-3 py-2 shadow-lg shadow-slate-900/10 backdrop-blur-sm sm:flex sm:items-center sm:gap-2">
        <span class="flex h-2 w-2 rounded-full bg-[var(--color-badge-blue)]" aria-hidden="true"></span>
        <span class="text-xs font-semibold text-foreground">6 consumibles con stock bajo</span>
      </div>
    </div>
  </div>
</section>
