---
import Icon from "./Icon.astro"

const items = [
  {
    icon: "box",
    title: "Inventario centralizado",
    description: "Cada equipo con su referencia, ubicación y estado en un único lugar.",
  },
  {
    icon: "loan",
    title: "Préstamos trazables",
    description: "Quién se lleva qué, desde cuándo y qué queda pendiente de devolver.",
  },
  {
    icon: "alert",
    title: "Incidencias con historial",
    description: "Averías con prioridad, asignación y seguimiento completo de cada caso.",
  },
  {
    icon: "lock",
    title: "Copias cifradas cada día",
    description: "Deduplicadas y con retención de hasta un año.",
  },
]
---

<section class="border-b border-border bg-[var(--color-surface-blue)]">
  <div class="section-wrap py-9 sm:py-10 lg:py-11">
    <div class="grid gap-5 sm:grid-cols-2 sm:gap-7 lg:grid-cols-4">
      {
        items.map((item) => (
          <div class="group flex items-start gap-3.5">
            <span class="icon-badge h-11 w-11">
              <Icon name={item.icon} class="h-5 w-5" />
            </span>
            <div>
              <h3 class="text-sm font-semibold leading-snug text-foreground">{item.title}</h3>
              <p class="mt-1 text-[0.92rem] leading-relaxed text-muted-foreground">{item.description}</p>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
